//! @file
//! CCCL @c <cuda/atomic> redirect for ROCm.
//! Tries hipDF's real CCCL first; falls back to std-based stubs.
//!
//! NOTE: only provides @c cuda::atomic / @c cuda::atomic_ref (the non-std
//! namespace). The @c cuda::std::atomic variants are provided by the
//! @c cuda/std/* redirects — defining them here too causes a redefinition
//! conflict when both headers are included.

#pragma once

#if __has_include_next(<cuda/atomic>)
  #include_next <cuda/atomic>
#else
  #include <atomic>

  namespace cuda {
  template <typename T> using atomic = ::std::atomic<T>;
  #if __cpp_lib_atomic_ref
  template <typename T> using atomic_ref = ::std::atomic_ref<T>;
  #endif
  using ::std::memory_order;
  using ::std::memory_order_relaxed;
  using ::std::memory_order_acquire;
  using ::std::memory_order_release;
  using ::std::memory_order_acq_rel;
  using ::std::memory_order_seq_cst;
  }  // namespace cuda
#endif
