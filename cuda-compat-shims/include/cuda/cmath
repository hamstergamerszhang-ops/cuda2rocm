//! @file
//! CCCL @c <cuda/cmath> redirect for ROCm.
//! Tries hipDF's real CCCL first via #include_next; falls back to a minimal
//! ::cuda::ceil_div if CCCL is not available.

#pragma once

#if __has_include_next(<cuda/cmath>)
  #include_next <cuda/cmath>
#else
  #include <cstdint>
  namespace cuda {
  template <typename A, typename B>
  __host__ __device__ constexpr auto ceil_div(A a, B b) -> decltype(a / b) {
    // Overflow-safe: (a + b - 1) / b can overflow when a is near SIZE_MAX.
    // a/b + (a%b != 0) never overflows.
    return a / b + (a % b != 0 ? 1 : 0);
  }
  }  // namespace cuda
#endif
