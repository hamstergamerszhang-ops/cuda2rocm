//! @file
//! CCCL @c <cuda/stream_ref> redirect for ROCm.
//! Tries hipDF's real CCCL first; falls back to minimal stream_ref.

#pragma once

#if __has_include_next(<cuda/stream_ref>)
  #include_next <cuda/stream_ref>
#else
  #include <hip/hip_runtime.h>

  namespace cuda {
  class stream_ref {
   public:
    stream_ref() = default;
    explicit stream_ref(hipStream_t s) : stream_(s) {}
    hipStream_t value() const { return stream_; }
    hipStream_t get() const { return stream_; }
    operator hipStream_t() const { return stream_; }
   private:
    hipStream_t stream_{};
  };
  }  // namespace cuda
#endif
